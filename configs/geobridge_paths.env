# Shared GeoBridge server paths.
#
# Source this file from launch scripts, or override any variable in the shell.
# The repository intentionally does not store datasets, model weights, caches,
# checkpoints, logs, or generated evaluation outputs.

export GEOBRIDGE_WORK_ROOT="${GEOBRIDGE_WORK_ROOT:-/mnt/guojh/lq/new}"
export GEOBRIDGE_CODE_ROOT="${GEOBRIDGE_CODE_ROOT:-${GEOBRIDGE_WORK_ROOT}/code/GeoBridge}"

export HF_ENDPOINT="${HF_ENDPOINT:-https://hf-mirror.com}"

export QWEN25VL_7B_PATH="${QWEN25VL_7B_PATH:-${GEOBRIDGE_WORK_ROOT}/models/Qwen/Qwen2.5-VL-7B-Instruct}"
export QWEN3VL_2B_PATH="${QWEN3VL_2B_PATH:-${GEOBRIDGE_WORK_ROOT}/models/Qwen/Qwen3-VL-2B-Instruct}"
export VGGT_1B_PATH="${VGGT_1B_PATH:-${GEOBRIDGE_WORK_ROOT}/weights/base_models/VGGT-1B}"

export STAGE1_WINDOW_READY_CACHE="${STAGE1_WINDOW_READY_CACHE:-${GEOBRIDGE_WORK_ROOT}/cache/GeoBridge/stage1_geobridge_window_ready_joint_fp16_g11}"
export STAGE1_FCP_CKPT="${STAGE1_FCP_CKPT:-${GEOBRIDGE_WORK_ROOT}/weights/stage1/checkpoint-9000.pt}"
export STAGE2_FINAL_CKPT="${STAGE2_FINAL_CKPT:-${GEOBRIDGE_WORK_ROOT}/weights/stage2/stage2_hgb_4gpu_7d_full_global64_bs8_ga2_layers0246_fixcollator_20260601/checkpoint-20887}"
export LEGACY_GEOBRIDGE_DATA_ROOT="${LEGACY_GEOBRIDGE_DATA_ROOT:-${GEOBRIDGE_WORK_ROOT}/code/spatial4nips/data}"

export STAGE2_DATASETS="${STAGE2_DATASETS:-llava_hound_64k,spar_234k,vsi_590k,vlm3r_vsi_205k,vlm3r_vst_132k,mindcube_10k,joyai_openspatial_100k}"
