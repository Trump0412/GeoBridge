# Shared SpatialFit paths. Override any variable in the shell.
# The repository does not store datasets, model weights, caches, checkpoints,
# logs, or generated evaluation outputs.

_SPATIALFIT_CONFIG_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
_SPATIALFIT_PROJECT_ROOT=$(cd "${_SPATIALFIT_CONFIG_DIR}/.." && pwd)

export SPATIALFIT_WORK_ROOT="${SPATIALFIT_WORK_ROOT:-${_SPATIALFIT_PROJECT_ROOT}/.local}"
export GEOBRIDGE_WORK_ROOT="${GEOBRIDGE_WORK_ROOT:-${SPATIALFIT_WORK_ROOT}}"
export GEOBRIDGE_CODE_ROOT="${GEOBRIDGE_CODE_ROOT:-${_SPATIALFIT_PROJECT_ROOT}}"
export HF_ENDPOINT="${HF_ENDPOINT:-https://hf-mirror.com}"

export SPATIALFIT_MODEL_ROOT="${SPATIALFIT_MODEL_ROOT:-${GEOBRIDGE_WORK_ROOT}/models}"
export QWEN25VL_7B_PATH="${QWEN25VL_7B_PATH:-${SPATIALFIT_MODEL_ROOT}/Qwen2.5-VL-7B-Instruct}"
export QWEN3VL_2B_PATH="${QWEN3VL_2B_PATH:-${SPATIALFIT_MODEL_ROOT}/Qwen3-VL-2B-Instruct}"
export VGGT_1B_PATH="${VGGT_1B_PATH:-${SPATIALFIT_MODEL_ROOT}/VGGT-1B}"

export STAGE1_WINDOW_READY_CACHE="${STAGE1_WINDOW_READY_CACHE:-${GEOBRIDGE_WORK_ROOT}/cache/spatialfit/stage1_window_ready_joint_fp16_g11}"
export STAGE1_FCP_CKPT="${STAGE1_FCP_CKPT:-${GEOBRIDGE_WORK_ROOT}/weights/stage1/checkpoint-9000.pt}"
export STAGE2_FINAL_CKPT="${STAGE2_FINAL_CKPT:-${GEOBRIDGE_WORK_ROOT}/weights/stage2/checkpoint-final}"
export LEGACY_GEOBRIDGE_DATA_ROOT="${LEGACY_GEOBRIDGE_DATA_ROOT:-${GEOBRIDGE_WORK_ROOT}/data}"

export STAGE2_DATASETS="${STAGE2_DATASETS:-llava_hound_64k,spar_234k,vsi_590k,vlm3r_vsi_205k,vlm3r_vst_132k,mindcube_10k,joyai_openspatial_100k}"
